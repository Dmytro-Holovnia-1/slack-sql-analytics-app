
# Get these from your Slack App settings: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Google Gemini API Key
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key

# Gemini Models
GEMINI_STANDARD_MODEL=gemini-3.1-flash-lite-preview
GEMINI_LOW_COST_MODEL=gemini-3.1-flash-lite-preview

# Logging Configuration
LOG_LEVEL=INFO

# LangSmith Observability Optional
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=rounds-slack-agent
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# PostgreSQL Runtime
POSTGRES_DB=rounds_analytics
POSTGRES_USER=rounds_admin
POSTGRES_PASSWORD=rounds_admin_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CHATBOT_DB_USER=chatbot_ro
CHATBOT_DB_PASSWORD=chatbot_ro_password
DB_STATEMENT_TIMEOUT_MS=5000
